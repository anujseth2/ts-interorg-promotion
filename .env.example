# Copy to .env and fill in. .env is git-ignored.

# ── ThoughtSpot ───────────────────────────────────────────────────────────────
TS_HOST=https://your-instance.thoughtspot.cloud
# Auth, in order of precedence:
#   1. TS_SECRET_KEY + TS_USER  -> mints a per-org token (use when SSO/MFA blocks basic login)
#   2. TS_USER + TS_PASSWORD    -> basic session login
#   3. TS_TOKEN                 -> a pre-minted bearer token
# The account must be a member of the orgs involved, and admin for variable management.
TS_TOKEN=
TS_USER=
TS_PASSWORD=
TS_SECRET_KEY=

# Primary org — where variables are created/managed (default 0)
TS_ORG_PRIMARY=0
# Source/authoring org to snapshot a release from (when not using --from-seed)
TS_ORG_SOURCE=0
# Tag marking the objects to release in the source org
TS_RELEASE_TAG=release

# Variable names = the ${tokens} injected into the parameterized TML
TS_DB_VAR=ts_db
TS_SCHEMA_VAR=ts_schema

# ── Git store (stores the parameterized release + per-org values) ─────────────
# Two backends:
#  A) LOCAL FOLDER (any path, e.g. inside your own git clone) - no token, no API, no
#     branch protection; you run git add/commit/push/PR yourself. Set GIT_LOCAL_DIR.
GIT_LOCAL_DIR=
#  B) GITHUB over the API - set GITHUB_REPO (owner/name) + GITHUB_TOKEN (repo scope).
GITHUB_REPO=your-org/ts-interorg-promotion
GITHUB_TOKEN=
# GitHub mode: commit the release to this branch and open a PR into main (use when main
# is protected / requires PRs). Blank = commit straight to main.
GIT_BRANCH=
# Optional: nest the release under a subfolder of the repo/folder (e.g. thoughtspot).
GIT_BASE_PATH=
